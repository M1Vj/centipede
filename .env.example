# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url

# Preferred for current Supabase projects.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Backwards-compatible fallback for older guides and projects.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key required for admin operations and scheduled competition starts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Strong random secret used to authorize scheduled competition cron requests.
CRON_SECRET=your-cron-secret
